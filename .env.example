NODE_ENV=production
PORT=3000
CLIENT_URL=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API token (https://supabase.com/dashboard/account/tokens)
# Used only by scripts/apply-supabase-auth-emails.js — never commit the real value.
SUPABASE_ACCESS_TOKEN=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_QUARTERLY=
STRIPE_PRICE_SOLO_SEMIANNUAL=
STRIPE_PRICE_SOLO_YEARLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_QUARTERLY=
STRIPE_PRICE_FAMILY_SEMIANNUAL=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_PRICE_FAMILY_PLUS_MONTHLY=
STRIPE_PRICE_FAMILY_PLUS_QUARTERLY=
STRIPE_PRICE_FAMILY_PLUS_SEMIANNUAL=
STRIPE_PRICE_FAMILY_PLUS_YEARLY=

JWT_SECRET=
SUPER_ADMIN_EMAILS=

SUPPORT_FROM_EMAIL=support@budgethubfamily.com
SUPPORT_ADMIN_EMAIL=support@budgethubfamily.com

# Optional SMTP settings for support ticket emails.
# If omitted, the backend logs support emails instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
